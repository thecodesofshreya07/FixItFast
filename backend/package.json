{
  "name": "fixitfast-backend",
  "version": "1.0.0",
  "description": "FixItFast backend API — Express + MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "nodemonConfig": {
    "watch": [
      "*.js",
      "routes/*.js"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/"
    ],
    "delay": "500"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "mongoose": "^9.4.1",
    "nodemailer": "^8.0.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
